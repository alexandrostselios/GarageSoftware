@section scripts{
    <script type="text/javascript">

        document.addEventListener('DOMContentLoaded', function () {
            var calendarEl = document.getElementById('calendar');
            if (!calendarEl) return;
            var today = '@Html.Raw(HttpUtility.JavaScriptStringEncode(Resource.GetKey("Home")))';
            // First create the calendar instance
            var calendar = new FullCalendar.Calendar(calendarEl, {
                locale: 'el',
                initialView: 'timeGridWeek',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay'
                },
                buttonText: {
                    today: '@Html.Raw(HttpUtility.JavaScriptStringEncode(Resource.GetKey("Calendar_Today")))',
                    month: '@Html.Raw(HttpUtility.JavaScriptStringEncode(Resource.GetKey("Calendar_Month")))',
                    week: '@Html.Raw(HttpUtility.JavaScriptStringEncode(Resource.GetKey("Calendar_Week")))',
                    day: '@Html.Raw(HttpUtility.JavaScriptStringEncode(Resource.GetKey("Calendar_Day")))'
                },
                selectable: true,
                // 🔄 Trigger re-fetch on view change
                datesSet: function (info) {
                    calendar.refetchEvents(); // Real events from your controller

                    // First remove previous dummy "allday-number" events only
                    calendar.getEvents().forEach(e => {
                        if (e.extendedProps && e.extendedProps.isDummy) {
                            e.remove();
                        }
                    });

                    // Then add new dummy events
                    addAllDayNumbers(info.view);
                }
                ,
                //Custom name. For later with literal
                allDayContent: function (arg) {
                    // Only show custom text in week view
                    if (arg.view.type != 'dayGridMonth') {
                        return { html: '<center><b>@Html.Raw(HttpUtility.JavaScriptStringEncode(Resource.GetKey("All_Day")))</b></center>' };
                    }

                    // Default for other views
                    return null;
                },
                eventDidMount: function (info) {
                    if (info.event.extendedProps.isDummy) {
                        return; // suppress tooltip
                    }
                    var tooltipContent =
                        `<strong>ID:</strong> ${info.event.id}<br>` +
                        `<strong>@Html.Raw(HttpUtility.JavaScriptStringEncode(Resource.GetKey("Customer_Name_Surname"))):</strong> ${info.event.extendedProps.customer}<br>` +
                        `<strong>@Html.Raw(HttpUtility.JavaScriptStringEncode(Resource.GetKey("Customer_Car"))):</strong> ${info.event.extendedProps.car}<br>` +
                        `<strong>@Html.Raw(HttpUtility.JavaScriptStringEncode(Resource.GetKey("Kilometer"))):</strong> ${info.event.extendedProps.kilometer}<br>` +
                        `<strong>@Html.Raw(HttpUtility.JavaScriptStringEncode(Resource.GetKey("Service_Appointment_Comments"))):</strong> ${info.event.title}<br>`;

                    tippy(info.el, {
                        content: tooltipContent,
                        allowHTML: true,
                        placement: 'top',
                        theme: 'light',
                    });

                    // Ensure text is black
                    var mainEl = info.el.querySelector('.fc-event-main');
                    if (mainEl) {
                        mainEl.style.setProperty('color', 'black', 'important');
                    }
                }
            });

            // // Add dummy all-day events to show '5' under each day in week view
            function addAllDayNumbers(view) {
                //console.log("Type: " + view.type);
                if (view.type === 'dayGridMonth') return;

                let garageId = @ViewBag.GarageID; // or get dynamically if needed
                const baseUrl = '@Resources.SettingsResources.Uri'
                var url = null;
                if (view.type === 'timeGridWeek') {
                    const startDate = new Date(view.currentStart);
                    const endDate = new Date(view.currentEnd - 1);

                    url = `${baseUrl}/GetDailyAppointmentCounts/${garageId}?start=${startDate.toISOString()}&end=${endDate.toISOString()}`;
                } else {
                    const date = new Date(view.currentStart);
                    const formatUTCDate = (date) => {
                        const year = date.getUTCFullYear();
                        const month = `${date.getUTCMonth() + 1}`.padStart(2, '0');
                        const day = `${date.getUTCDate()+1}`.padStart(2, '0');
                        return `${year}-${month}-${day}`;
                    };
                    const formattedDate = formatUTCDate(date);

                    url = `${baseUrl}/GetDailyAppointmentCounts/${garageId}?start=${formattedDate}&end=${formattedDate}`;
                }
                fetch(url)
                    .then(res => res.json())
                    .then(data => {
                        data.forEach(day => {
                            calendar.addEvent({
                                title: '@Html.Raw(HttpUtility.JavaScriptStringEncode(Resource.GetKey("Total"))): (' + day.count.toString() + ')',
                                start: day.date,
                                allDay: true,
                                display: 'auto',
                                backgroundColor: 'transparent',
                                borderColor: 'transparent',
                                textColor: '#000',
                                className: 'allday-number',
                                extendedProps: {
                                    isDummy: true
                                }
                            });
                        });
                    });
                
            }
            // Now add event source dynamically with a function for extraParams
            calendar.addEventSource({
                url: '@Url.Action("GetServiceAppointmentsJSON", "ServiceAppointment")',
                method: 'GET',
                extraParams: function () {
                    return {
                        customerID: 0,
                        menu: 0,
                        monthView: calendar.view && calendar.view.type === 'dayGridMonth' ? 0 : 1
                    };
                },
                failure: function () {
                    alert('Error fetching events!');
                }
            });

            calendar.render();
        });



        //Show Add Make Modal
        $(function () {
            var QuickAddCarServiceHistoryElement = $('#quickAddCarServiceHistoryDIV');

            $('button[data-bs-toggle="ajax-modal"]').click(function (event) {
                var url = $(this).data('url');
                $.get(url).done(function (data) {
                    QuickAddCarServiceHistoryElement.html(data);
                    QuickAddCarServiceHistoryElement.find('.modal').modal('show');
                })
            })

            //Save Add Makeform data
            QuickAddCarServiceHistoryElement.on('click', '[data-bs-save="modal"]', function (event) {

                var form = $(this).parents('.modal').find('form');
                var actionUrl = form.attr("action");
                var sendData = form.serialize();
                $.post(actionUrl, sendData).done(function (data) {
                    QuickAddCarServiceHistoryElement.find('.modal').modal('hide');
                    location.reload(true);
                })
            })

        })

