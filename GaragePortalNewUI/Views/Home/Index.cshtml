                success: function (response) {
                    if (response.success) {
                        // ✅ Refresh the whole page to reload data
                        location.reload();
                    } else {
                        alert("Update failed: " + response.message);
                    }
                },
                error: function () {
                    alert("Error updating appointment.");
                }
            });
