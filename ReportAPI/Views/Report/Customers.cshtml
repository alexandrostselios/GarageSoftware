@using System.Collections.Generic
@model IEnumerable<ReportAPI.Models.Customer>

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Customers</title>
    <style>
        table {
            border-collapse: collapse;
            width: 100%;
        }
        th, td {
            border: 1px solid #ccc;
            padding: 8px;
            text-align: center;
        }
        th {
            background-color: lightgreen;
        }
    </style>
</head>
<body>
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Surname</th>
                <th>Mobile</th>
                <th>Email</th>
                <th>Comments</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var customer in Model)
            {
                <tr>
                    <td>@customer.CustomerID</td>
                    <td>@customer.CustomerName</td>
                    <td>@customer.CustomerSurname</td>
                    <td>@customer.CustomerMobilePhone</td>
                    <td>@customer.CustomerEmail</td>
                    <td>@customer.CustomerComment</td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>
